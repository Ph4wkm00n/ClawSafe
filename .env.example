# ClawSafe environment variables

# Backend
CLAWSAFE_PORT=8000
CLAWSAFE_DATABASE_PATH=clawsafe.db
CLAWSAFE_OPENCLAW_CONFIG_PATH=/etc/openclaw/config.yaml
CLAWSAFE_FRONTEND_URL=http://localhost:3000
CLAWSAFE_DEBUG=false

# Authentication (leave empty to disable — for dev only)
CLAWSAFE_API_KEY=

# Scanning
CLAWSAFE_SCAN_INTERVAL=3600
CLAWSAFE_DEMO_MODE=true
CLAWSAFE_LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=

# Docker Compose (SMB overlay)
CLAWSAFE_METRICS_PORT=9090
